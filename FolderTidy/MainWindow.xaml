<Window x:Class="FolderTidy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:FolderTidy.ViewModels"
        mc:Ignorable="d"
        Title="FolderTidy - 폴더 정리"
        Icon="Assets/FolderTidy.ico"
        Height="860"
        Width="1280"
        MinHeight="640"
        MinWidth="960"
        PreviewKeyDown="Window_PreviewKeyDown"
        Background="{StaticResource AppBackgroundBrush}">
    <Window.Resources>
        <DataTemplate x:Key="OccupancyBarTemplate">
            <Grid Height="20"
                  MinWidth="96"
                  Margin="4,0">
                <Border Background="#1E293B"
                        CornerRadius="2"
                        Opacity="0.12" />
                <Grid Margin="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="{Binding OccupancyPercent, Converter={StaticResource PercentToStarGridLengthConverter}}" />
                        <ColumnDefinition Width="{Binding OccupancyPercent, Converter={StaticResource PercentToRemainingStarGridLengthConverter}}" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0"
                            Background="{StaticResource AccentBrush}"
                            CornerRadius="1" />
                </Grid>
                <TextBlock Text="{Binding OccupancyPercentText}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource StrongTextBrush}" />
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="FileEntryCardTemplate">
            <Border Margin="0,0,0,1"
                    Padding="6,4"
                    Background="White"
                    BorderBrush="{Binding IsSelected, Converter={StaticResource SelectionBorderBrushConverter}}"
                    BorderThickness="{Binding IsSelected, Converter={StaticResource SelectionBorderThicknessConverter}}"
                    CornerRadius="4"
                    Opacity="{Binding IsDimmedInList, Converter={StaticResource BoolToOpacityConverter}, ConverterParameter=0.45}"
                    Cursor="Hand"
                    MouseLeftButtonDown="FileCard_MouseLeftButtonDown">
                <Grid MinHeight="28">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="28" />
                        <ColumnDefinition Width="2.4*" MinWidth="180" />
                        <ColumnDefinition Width="88" />
                        <ColumnDefinition Width="96" />
                        <ColumnDefinition Width="96" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <CheckBox Grid.Column="0"
                              VerticalAlignment="Center"
                              IsChecked="{Binding IsSelected, Mode=OneWay}"
                              Click="FileSelectionCheckBox_Click" />

                    <StackPanel Grid.Column="1"
                                Margin="4,0,8,0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Background="Transparent"
                                MouseLeftButtonDown="FileName_MouseLeftButtonDown">
                        <Image Source="{Binding FileIcon}"
                               Width="16"
                               Height="16"
                               Stretch="Uniform"
                               Margin="0,0,8,0"
                               VerticalAlignment="Center"
                               Visibility="{Binding ShowFileIcon, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <Border Width="{Binding ThumbnailPixelSize}"
                                Height="{Binding ThumbnailPixelSize}"
                                Margin="0,0,8,0"
                                CornerRadius="4"
                                Background="{StaticResource HighlightBrush}"
                                VerticalAlignment="Center"
                                Visibility="{Binding ShowListThumbnail, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Image Source="{Binding Preview}"
                                   Stretch="UniformToFill"
                                   Margin="2" />
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Name}"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"
                                           MaxWidth="420" />
                                <TextBlock Text="{Binding Extension}"
                                           Margin="8,0,0,0"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="{Binding StatusLabel}"
                                           Margin="8,0,0,0"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding StatusLabel, Converter={StaticResource StringNotEmptyToVisibilityConverter}}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#DC2626" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsPendingBackup}" Value="True">
                                                    <Setter Property="Foreground" Value="#059669" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal"
                                        Margin="0,2,0,0"
                                        Visibility="{Binding LocationText, Converter={StaticResource StringNotEmptyToVisibilityConverter}}">
                                <TextBlock Text="{Binding InfoText}"
                                           FontSize="11"
                                           Foreground="{StaticResource MutedTextBrush}" />
                                <TextBlock Text="{Binding LocationText}"
                                           Margin="8,0,0,0"
                                           FontSize="11"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextTrimming="CharacterEllipsis"
                                           MaxWidth="320" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Grid.Column="2"
                               Text="{Binding SizeText}"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource AccentBrush}" />

                    <TextBlock Grid.Column="3"
                               Text="{Binding CreatedText}"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource StrongTextBrush}" />

                    <TextBlock Grid.Column="4"
                               Text="{Binding ModifiedText}"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource StrongTextBrush}" />

                    <ContentControl Grid.Column="5"
                                    VerticalAlignment="Center"
                                    Content="{Binding}"
                                    ContentTemplate="{StaticResource OccupancyBarTemplate}" />

                    <StackPanel Grid.Column="6"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button Padding="8,3"
                                Style="{StaticResource DangerButtonStyle}"
                                Content="삭제"
                                Visibility="{Binding IsActiveInList, Converter={StaticResource BoolToVisibilityConverter}}"
                                Command="{Binding DataContext.MarkForDeletionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}" />
                        <Button Padding="8,3"
                                Style="{StaticResource BackupButtonStyle}"
                                Content="백업"
                                Visibility="{Binding IsActiveInList, Converter={StaticResource BoolToVisibilityConverter}}"
                                Command="{Binding DataContext.MarkForBackupCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}" />
                        <Button Padding="8,3"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Content="복원"
                                Visibility="{Binding IsPendingDeletion, Converter={StaticResource BoolToVisibilityConverter}}"
                                Command="{Binding DataContext.RestoreFromPendingCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}" />
                        <Button Padding="8,3"
                                Margin="0"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Content="복원"
                                Visibility="{Binding IsPendingBackup, Converter={StaticResource BoolToVisibilityConverter}}"
                                Command="{Binding DataContext.RestoreFromPendingBackupCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="PendingFileEntryCardTemplate">
            <Border Margin="0,0,0,1"
                    Padding="6,4"
                    Background="White"
                    BorderBrush="{StaticResource BorderBrushColor}"
                    BorderThickness="1"
                    CornerRadius="4">
                <Grid MinHeight="28">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.4*" MinWidth="180" />
                        <ColumnDefinition Width="88" />
                        <ColumnDefinition Width="96" />
                        <ColumnDefinition Width="96" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Margin="4,0,8,0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Image Source="{Binding FileIcon}"
                               Width="16"
                               Height="16"
                               Stretch="Uniform"
                               Margin="0,0,8,0"
                               VerticalAlignment="Center" />
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding Name}"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Margin="0,2,0,0"
                                       FontSize="11"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Text="{Binding CategoryName}" />
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Grid.Column="1"
                               Text="{Binding SizeText}"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource AccentBrush}" />

                    <TextBlock Grid.Column="2"
                               Text="{Binding CreatedText}"
                               VerticalAlignment="Center" />

                    <TextBlock Grid.Column="3"
                               Text="{Binding ModifiedText}"
                               VerticalAlignment="Center" />

                    <ContentControl Grid.Column="4"
                                    VerticalAlignment="Center"
                                    Content="{Binding}"
                                    ContentTemplate="{StaticResource OccupancyBarTemplate}" />

                    <StackPanel Grid.Column="5"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button Padding="8,3"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Content="복원"
                                Command="{Binding DataContext.RestoreFromPendingCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}" />
                        <Button Padding="8,3"
                                Margin="0"
                                Style="{StaticResource DangerButtonStyle}"
                                Content="완전 삭제"
                                Click="PermanentlyDeleteSinglePendingButton_Click"
                                Tag="{Binding}" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="PendingBackupFileEntryCardTemplate">
            <Border Margin="0,0,0,1"
                    Padding="6,4"
                    Background="White"
                    BorderBrush="{StaticResource BorderBrushColor}"
                    BorderThickness="1"
                    CornerRadius="4">
                <Grid MinHeight="28">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.4*" MinWidth="180" />
                        <ColumnDefinition Width="88" />
                        <ColumnDefinition Width="96" />
                        <ColumnDefinition Width="96" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Margin="4,0,8,0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Image Source="{Binding FileIcon}"
                               Width="16"
                               Height="16"
                               Stretch="Uniform"
                               Margin="0,0,8,0"
                               VerticalAlignment="Center" />
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding Name}"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Margin="0,2,0,0"
                                       FontSize="11"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Text="{Binding CategoryName}" />
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Grid.Column="1"
                               Text="{Binding SizeText}"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource AccentBrush}" />

                    <TextBlock Grid.Column="2"
                               Text="{Binding CreatedText}"
                               VerticalAlignment="Center" />

                    <TextBlock Grid.Column="3"
                               Text="{Binding ModifiedText}"
                               VerticalAlignment="Center" />

                    <ContentControl Grid.Column="4"
                                    VerticalAlignment="Center"
                                    Content="{Binding}"
                                    ContentTemplate="{StaticResource OccupancyBarTemplate}" />

                    <StackPanel Grid.Column="5"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button Padding="8,3"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Content="복원"
                                Command="{Binding DataContext.RestoreFromPendingBackupCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}" />
                        <Button Padding="8,3"
                                Margin="0"
                                Style="{StaticResource BackupButtonStyle}"
                                Content="백업 실행"
                                Click="ExecuteBackupSinglePendingButton_Click"
                                Tag="{Binding}" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrushColor}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="16"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="FolderTidy"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="{StaticResource StrongTextBrush}" />
                    <TextBlock Text="어수선한 폴더를 종류별로 보고 삭제·백업으로 정리합니다."
                               Margin="0,4,0,0"
                               Foreground="{StaticResource MutedTextBrush}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="폴더 열기"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding OpenFolderCommand}" />
                    <Button Content="불러오기"
                            Command="{Binding RefreshCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrushColor}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="12"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="경로 선택"
                        Command="{Binding BrowseCommand}" />

                <TextBox Grid.Column="1"
                         Margin="8,0"
                         Text="{Binding SelectedPath, UpdateSourceTrigger=PropertyChanged}"
                         KeyDown="PathTextBox_KeyDown" />

                <TextBlock Grid.Column="2"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource MutedTextBrush}"
                           Text="Enter 또는 불러오기로 갱신" />
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrushColor}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="12"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <CheckBox Grid.Column="0"
                          Content="하위 폴더 포함"
                          IsChecked="{Binding IncludeSubfolders}" />

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Margin="24,0,0,0"
                            VerticalAlignment="Center">
                    <TextBlock Text="세부 그룹:"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"
                               Foreground="{StaticResource StrongTextBrush}" />
                    <ComboBox ItemsSource="{Binding SubGroupOptions}"
                              SelectedItem="{Binding SelectedSubGroupOption}"
                              DisplayMemberPath="DisplayName"
                              Margin="0,0,16,0" />
                    <TextBlock Text="그룹 정렬:"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"
                               Foreground="{StaticResource StrongTextBrush}" />
                    <ComboBox ItemsSource="{Binding GroupSortOptions}"
                              SelectedItem="{Binding SelectedGroupSortOption}"
                              DisplayMemberPath="DisplayName"
                              Margin="0,0,16,0" />
                    <TextBlock Text="썸네일:"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"
                               Foreground="{StaticResource StrongTextBrush}" />
                    <ComboBox ItemsSource="{Binding ThumbnailSizeOptions}"
                              SelectedItem="{Binding SelectedThumbnailSizeOption}"
                              DisplayMemberPath="DisplayName" />
                </StackPanel>

                <TextBlock Grid.Column="2"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource AccentBrush}"
                           Text="{Binding StatusText}" />
            </Grid>
        </Border>

        <Border Grid.Row="3"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrushColor}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="12"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource MutedTextBrush}"
                           Text="{Binding SelectionText}" />

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="선택 해제"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding ClearSelectionCommand}" />
                    <Button Content="선택 항목 백업 예정"
                            Style="{StaticResource BackupButtonStyle}"
                            Command="{Binding MarkForBackupCommand}" />
                    <Button Content="선택 항목 삭제 예정"
                            Style="{StaticResource DangerButtonStyle}"
                            Command="{Binding MarkForDeletionCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <TabControl x:Name="MainTabControl" Grid.Row="4">
            <TabItem Header="파일 목록">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="360" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="320" MinWidth="240" />
                    </Grid.ColumnDefinitions>

                    <ScrollViewer Grid.Column="0"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding FileGroups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Expander IsExpanded="False"
                                              Expanded="CategoryExpander_Expanded">
                                        <Expander.Header>
                                            <Grid Margin="4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="160" />
                                                    <ColumnDefinition Width="88" />
                                                    <ColumnDefinition Width="72" />
                                                    <ColumnDefinition Width="120" />
                                                    <ColumnDefinition Width="*" MinWidth="140" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding CategoryName}"
                                                           FontSize="16"
                                                           FontWeight="Bold"
                                                           VerticalAlignment="Center"
                                                           Foreground="{StaticResource StrongTextBrush}" />

                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding TotalSizeText}"
                                                           FontSize="14"
                                                           FontWeight="Bold"
                                                           VerticalAlignment="Center"
                                                           Foreground="{StaticResource AccentBrush}" />

                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding FileCountText}"
                                                           VerticalAlignment="Center"
                                                           Foreground="{StaticResource StrongTextBrush}" />

                                                <ContentControl Grid.Column="3"
                                                                VerticalAlignment="Center"
                                                                Content="{Binding}"
                                                                ContentTemplate="{StaticResource OccupancyBarTemplate}" />

                                                <TextBlock Grid.Column="4"
                                                           Text="{Binding DateRangeText}"
                                                           FontSize="12"
                                                           VerticalAlignment="Center"
                                                           Foreground="{StaticResource MutedTextBrush}" />
                                            </Grid>
                                        </Expander.Header>

                                        <StackPanel Margin="8,0,8,8">
                                            <Border Background="#F8FAFC"
                                                    BorderBrush="{StaticResource BorderBrushColor}"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Padding="6,4"
                                                    Margin="0,0,0,4">
                                                <Grid MinHeight="24">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="28" />
                                                        <ColumnDefinition Width="2.4*" MinWidth="180" />
                                                        <ColumnDefinition Width="88" />
                                                        <ColumnDefinition Width="96" />
                                                        <ColumnDefinition Width="96" />
                                                        <ColumnDefinition Width="120" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <CheckBox Grid.Column="0"
                                                              VerticalAlignment="Center"
                                                              HorizontalAlignment="Center"
                                                              IsThreeState="True"
                                                              ToolTip="그룹 전체 선택"
                                                              Tag="{Binding}"
                                                              PreviewMouseDown="GroupSelectAllCheckBox_PreviewMouseDown"
                                                              Click="GroupSelectAllCheckBox_Click" />

                                                    <TextBlock Grid.Column="1"
                                                               Text="파일"
                                                               VerticalAlignment="Center"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource MutedTextBrush}" />

                                                    <TextBlock Grid.Column="2"
                                                               Text="용량"
                                                               VerticalAlignment="Center"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource MutedTextBrush}" />

                                                    <TextBlock Grid.Column="3"
                                                               Text="생성일"
                                                               VerticalAlignment="Center"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource MutedTextBrush}" />

                                                    <TextBlock Grid.Column="4"
                                                               Text="수정일"
                                                               VerticalAlignment="Center"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource MutedTextBrush}" />

                                                    <TextBlock Grid.Column="5"
                                                               Text="폴더 점유율"
                                                               VerticalAlignment="Center"
                                                               HorizontalAlignment="Center"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource MutedTextBrush}" />

                                                    <TextBlock Grid.Column="6"
                                                               Text="작업"
                                                               VerticalAlignment="Center"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource MutedTextBrush}" />
                                                </Grid>
                                            </Border>

                                            <ItemsControl ItemsSource="{Binding SubGroups}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Margin="0,0,0,4">
                                                            <Border Background="{StaticResource AccentSoftBrush}"
                                                                    CornerRadius="6"
                                                                    Padding="8,4"
                                                                    Margin="0,0,0,4"
                                                                    Visibility="{Binding ShowSectionHeader, Converter={StaticResource BoolToVisibilityConverter}}">
                                                                <Grid MinHeight="24">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="88" />
                                                                        <ColumnDefinition Width="72" />
                                                                        <ColumnDefinition Width="120" />
                                                                    </Grid.ColumnDefinitions>

                                                                    <TextBlock Text="{Binding Label}"
                                                                               FontWeight="SemiBold"
                                                                               VerticalAlignment="Center" />

                                                                    <TextBlock Grid.Column="1"
                                                                               Text="{Binding TotalSizeText}"
                                                                               FontWeight="Bold"
                                                                               Foreground="{StaticResource AccentBrush}"
                                                                               VerticalAlignment="Center" />

                                                                    <TextBlock Grid.Column="2"
                                                                               Text="{Binding FileCountText}"
                                                                               Foreground="{StaticResource MutedTextBrush}"
                                                                               VerticalAlignment="Center" />

                                                                    <ContentControl Grid.Column="3"
                                                                                    VerticalAlignment="Center"
                                                                                    Content="{Binding}"
                                                                                    ContentTemplate="{StaticResource OccupancyBarTemplate}" />
                                                                </Grid>
                                                            </Border>

                                                            <ItemsControl ItemsSource="{Binding Files}"
                                                                          ItemTemplate="{StaticResource FileEntryCardTemplate}" />
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Expander>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <GridSplitter Grid.Column="1"
                                  Width="6"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Stretch"
                                  Background="{StaticResource BorderBrushColor}"
                                  ShowsPreview="True"
                                  ResizeBehavior="PreviousAndNext" />

                    <Border Grid.Column="2"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource BorderBrushColor}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="16">
                        <DockPanel LastChildFill="True">
                            <TextBlock DockPanel.Dock="Top"
                                       Text="미리보기"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Margin="0,0,0,8" />
                            <TextBlock DockPanel.Dock="Top"
                                       Text="{Binding FilePreview.Title}"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,4" />
                            <TextBlock DockPanel.Dock="Top"
                                       Text="{Binding FilePreview.Description}"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,4" />
                            <TextBlock DockPanel.Dock="Top"
                                       Text="{Binding FilePreview.Hint}"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextWrapping="Wrap"
                                       FontSize="11"
                                       Margin="0,0,0,12" />

                            <Border Background="{StaticResource AccentSoftBrush}"
                                    CornerRadius="10"
                                    MinHeight="240">
                                <Grid>
                                    <TextBlock Text="파일 1개를 선택하면&#x0a;미리보기가 표시됩니다."
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               TextAlignment="Center"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               Visibility="{Binding FilePreview.ShowEmptyPlaceholder, Converter={StaticResource BoolToVisibilityConverter}}" />

                                    <StackPanel HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Visibility="{Binding FilePreview.IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <ProgressBar IsIndeterminate="True"
                                                     Width="180"
                                                     Height="4"
                                                     Margin="0,0,0,10" />
                                        <TextBlock Text="미리보기 불러오는 중..."
                                                   HorizontalAlignment="Center"
                                                   Foreground="{StaticResource MutedTextBrush}" />
                                    </StackPanel>

                                    <Image Source="{Binding FilePreview.PreviewImage}"
                                           Stretch="Uniform"
                                           Margin="12"
                                           Visibility="{Binding FilePreview.ShowImagePreview, Converter={StaticResource BoolToVisibilityConverter}}" />

                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Auto"
                                                  Margin="8"
                                                  Visibility="{Binding FilePreview.ShowTextPreview, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBox Text="{Binding FilePreview.PreviewText, Mode=OneWay}"
                                                 IsReadOnly="True"
                                                 BorderThickness="0"
                                                 Background="Transparent"
                                                 FontFamily="Consolas"
                                                 FontSize="12"
                                                 TextWrapping="NoWrap"
                                                 AcceptsReturn="True"
                                                 AcceptsTab="True" />
                                    </ScrollViewer>

                                    <Grid Margin="0"
                                          Visibility="{Binding FilePreview.ShowTreePreview, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <Border Grid.Row="0"
                                                Background="#F3F3F3"
                                                BorderBrush="#D0D0D0"
                                                BorderThickness="0,0,0,1"
                                                Padding="28,6,12,6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" MinWidth="120" />
                                                    <ColumnDefinition Width="72" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="이름"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource StrongTextBrush}" />
                                                <TextBlock Grid.Column="1"
                                                           Text="크기"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           HorizontalAlignment="Right"
                                                           Foreground="{StaticResource StrongTextBrush}" />
                                            </Grid>
                                        </Border>

                                        <TreeView Grid.Row="1"
                                                  ItemsSource="{Binding FilePreview.ArchiveTreeRoot.Children}"
                                                  Background="White"
                                                  BorderThickness="0"
                                                  Padding="0,4,0,4">
                                            <TreeView.Resources>
                                                <Style TargetType="TreeViewItem">
                                                    <Setter Property="IsExpanded" Value="True" />
                                                    <Setter Property="Padding" Value="2,1" />
                                                    <Setter Property="Background" Value="Transparent" />
                                                    <Setter Property="BorderThickness" Value="0" />
                                                    <Style.Triggers>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter Property="Background" Value="#CCE8FF" />
                                                        </Trigger>
                                                        <MultiTrigger>
                                                            <MultiTrigger.Conditions>
                                                                <Condition Property="IsSelected" Value="False" />
                                                                <Condition Property="IsMouseOver" Value="True" />
                                                            </MultiTrigger.Conditions>
                                                            <Setter Property="Background" Value="#E5F3FF" />
                                                        </MultiTrigger>
                                                    </Style.Triggers>
                                                </Style>

                                                <HierarchicalDataTemplate DataType="{x:Type viewModels:ArchiveTreeNodeViewModel}"
                                                                          ItemsSource="{Binding Children}">
                                                    <Grid Margin="0,1">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="20" />
                                                            <ColumnDefinition Width="*" MinWidth="120" />
                                                            <ColumnDefinition Width="72" />
                                                        </Grid.ColumnDefinitions>

                                                        <Image Grid.Column="0"
                                                               Source="{Binding Icon}"
                                                               Width="16"
                                                               Height="16"
                                                               Margin="0,0,4,0"
                                                               VerticalAlignment="Center" />

                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding Name}"
                                                                   VerticalAlignment="Center"
                                                                   TextTrimming="CharacterEllipsis" />

                                                        <TextBlock Grid.Column="2"
                                                                   Text="{Binding SizeDisplay}"
                                                                   VerticalAlignment="Center"
                                                                   HorizontalAlignment="Right"
                                                                   Foreground="{StaticResource MutedTextBrush}" />
                                                    </Grid>
                                                </HierarchicalDataTemplate>
                                            </TreeView.Resources>
                                        </TreeView>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="{Binding PendingDeletionTabHeader}">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{StaticResource AccentSoftBrush}"
                            CornerRadius="10"
                            Padding="12"
                            Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="삭제 예정 목록"
                                           FontSize="16"
                                           FontWeight="Bold" />
                                <TextBlock Margin="0,4,0,0"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           Text="여기서 최종 검토 후 완전 삭제합니다. 휴지통으로 보내지 않습니다." />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Content="선택 복원"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Click="RestorePendingButton_Click" />
                                <Button Content="선택 완전 삭제"
                                        Style="{StaticResource DangerButtonStyle}"
                                        Click="PermanentlyDeletePendingButton_Click" />
                                <Button Content="전체 완전 삭제"
                                        Style="{StaticResource DangerButtonStyle}"
                                        Command="{Binding PermanentlyDeletePendingCommand}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <ListBox x:Name="PendingDeletionListBox"
                             Grid.Row="1"
                             ItemsSource="{Binding PendingDeletionFiles}"
                             SelectionMode="Extended"
                             BorderThickness="0"
                             Background="Transparent"
                             ItemTemplate="{StaticResource PendingFileEntryCardTemplate}">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <ContentPresenter />
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Grid>
            </TabItem>

            <TabItem Header="{Binding PendingBackupTabHeader}">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="#ECFDF5"
                            BorderBrush="#A7F3D0"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="12"
                            Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0"
                                    Content="백업 경로"
                                    Style="{StaticResource BackupButtonStyle}"
                                    Command="{Binding BrowseBackupFolderCommand}" />

                            <TextBox Grid.Column="1"
                                     Margin="8,0"
                                     Text="{Binding BackupDestinationPath, UpdateSourceTrigger=PropertyChanged}" />

                            <CheckBox Grid.Column="2"
                                      Content="파일 종류별 자동 폴더 생성"
                                      IsChecked="{Binding CreateCategoryFoldersOnBackup}"
                                      VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="1"
                            Background="{StaticResource AccentSoftBrush}"
                            CornerRadius="10"
                            Padding="12"
                            Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="백업 예정 목록"
                                           FontSize="16"
                                           FontWeight="Bold" />
                                <TextBlock Margin="0,4,0,0"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           Text="백업 폴더를 선택한 뒤 파일을 이동합니다. 원본 위치에서는 제거됩니다." />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Content="선택 복원"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Click="RestorePendingBackupButton_Click" />
                                <Button Content="선택 백업 실행"
                                        Style="{StaticResource BackupButtonStyle}"
                                        Click="ExecuteBackupPendingButton_Click" />
                                <Button Content="전체 백업 실행"
                                        Style="{StaticResource BackupButtonStyle}"
                                        Command="{Binding ExecuteBackupPendingCommand}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <ListBox x:Name="PendingBackupListBox"
                             Grid.Row="2"
                             ItemsSource="{Binding PendingBackupFiles}"
                             SelectionMode="Extended"
                             BorderThickness="0"
                             Background="Transparent"
                             ItemTemplate="{StaticResource PendingBackupFileEntryCardTemplate}">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <ContentPresenter />
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
